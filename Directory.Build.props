<Project>
  <!-- Single source of truth for app + installer version. Bump here only; build scripts pass this to Inno (ISCC /DAppVersion=…). -->
  <PropertyGroup>
    <Version>1.0.2.5</Version>
    <!-- AssemblyVersion / FileVersion: exactly four ushort parts (Major.Minor.Build.Revision). A fifth part breaks WPF (MC1005). -->
    <AssemblyVersion>1.0.2.5</AssemblyVersion>
    <FileVersion>1.0.2.5</FileVersion>
  </PropertyGroup>
</Project>
