<Window x:Class="WhatAmIDoing.RuleInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rule match — foreground window"
        Width="560" Height="520"
        MinWidth="420"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner">
    <Border Margin="16" Background="White" CornerRadius="10" Padding="14" BorderBrush="#E8EAEF" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Updates every 2 seconds. Same logic as activity sampling." TextWrapping="Wrap"
                           Foreground="#5C6370" VerticalAlignment="Center"/>
                <Button Content="Refresh now" Padding="10,4" Margin="12,0,0,0" Click="Refresh_OnClick"/>
                <Button Content="Close" Padding="10,4" Margin="8,0,0,0" IsCancel="True" Click="Close_OnClick"/>
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="BodyText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                           Foreground="#1E2430"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
