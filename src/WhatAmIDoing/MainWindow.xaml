<Window x:Class="WhatAmIDoing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What Am I Doing"
        Height="720" Width="1080"
        MinHeight="540" MinWidth="820"
        Background="#F4F6F9"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico"
        Closing="MainWindow_OnClosing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="What Am I Doing" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="  —  local activity report" Margin="8,0,0,0" Foreground="#5C6370" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                BorderBrush="#E8EAEF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Day" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="DayPicker" Grid.Column="1" Width="140" SelectedDateChanged="DayPicker_OnSelectedDateChanged"/>
                <TextBlock Grid.Column="2" Text="Range" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox x:Name="RangeMode" Grid.Column="3" Width="220" HorizontalAlignment="Left"
                          SelectionChanged="RangeMode_OnSelectionChanged">
                    <ComboBoxItem Content="This calendar day" IsSelected="True"/>
                    <ComboBoxItem Content="7 days ending on selected day"/>
                </ComboBox>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Refresh" Padding="12,6" Margin="0,0,8,0" Click="Refresh_OnClick"/>
                    <Button Content="Settings…" Padding="12,6" Margin="0,0,8,0" Click="Settings_OnClick"/>
                    <Button Content="Rules…" Padding="12,6" Margin="0,0,8,0" Click="Rules_OnClick"/>
                    <Button Content="Export HTML…" Padding="12,6" Click="Export_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                BorderBrush="#E8EAEF" BorderThickness="1">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ChartTitle" Text="Hourly activity"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <WrapPanel x:Name="LegendPanel" Grid.Column="1" Margin="16,0,0,0"
                               Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <Canvas x:Name="ChartCanvas" Height="160" Background="Transparent"
                        SizeChanged="ChartCanvas_OnSizeChanged"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,8"
                        BorderBrush="#E8EAEF" BorderThickness="1" MinHeight="120">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Summary" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <TextBlock x:Name="SummaryText" TextWrapping="Wrap" Foreground="#3D4450" FontSize="13"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="8"
                        BorderBrush="#E8EAEF" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Highlights (active time)" FontWeight="SemiBold" Margin="4,4,4,6"/>
                        <TabControl x:Name="HighlightsTabs" BorderThickness="0" Background="Transparent">
                            <TabItem Header="YouTube">
                                <DataGrid x:Name="YouTubeGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserResizeRows="False" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Video" Binding="{Binding Label}" Width="*"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Sites / pages">
                                <DataGrid x:Name="SiteGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserResizeRows="False" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Page title" Binding="{Binding Label}" Width="*"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Projects">
                                <DataGrid x:Name="ProjectGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserResizeRows="False" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project / folder" Binding="{Binding Label}" Width="*"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="8" Margin="0,0,0,8"
                        BorderBrush="#E8EAEF" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="By category (double-click for details)"
                                   FontWeight="SemiBold" Margin="4,4,4,6"/>
                        <DataGrid x:Name="CategoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  CanUserResizeRows="False" BorderThickness="0" Background="Transparent"
                                  MouseDoubleClick="CategoryGrid_OnMouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="80"/>
                                <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="80"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Time}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="8"
                        BorderBrush="#E8EAEF" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="By app (engaged time)" FontWeight="SemiBold" Margin="4,4,4,6"/>
                        <DataGrid x:Name="ProcessGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  CanUserResizeRows="False" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="*"/>
                                <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="80"/>
                                <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="80"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Time}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
