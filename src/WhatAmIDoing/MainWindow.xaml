<Window x:Class="WhatAmIDoing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What Am I Doing"
        Height="760" Width="1120"
        MinHeight="520" MinWidth="760"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico"
        Closing="MainWindow_OnClosing"
        SizeChanged="MainWindow_OnSizeChanged">
    <Grid Margin="18,16,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="What Am I Doing" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource DashTextPrimaryBrush}"/>
                <TextBlock Text="Local activity report — private on this PC"
                           FontSize="13" Foreground="{StaticResource DashTextMutedBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="TrackingHelpButton" Content="?" Width="32" Height="32" Padding="0" Margin="0,0,10,0"
                        ToolTip="How tracking works (Active, Thinking, Idle)"
                        Style="{StaticResource DashToolbarButton}" Click="TrackingHelp_OnClick"/>
                <Button x:Name="DashboardTourButton" Content="Catch up" Padding="10,6" Margin="0,0,10,0"
                        ToolTip="Open the dashboard walkthrough"
                        Style="{StaticResource DashToolbarButton}" Click="DashboardTour_OnClick"/>
                <TextBlock x:Name="MetricRangeLabel" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource DashTextMutedBrush}"
                           TextAlignment="Right" TextWrapping="Wrap" MaxWidth="220"/>
            </StackPanel>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource DashCardBorder}" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Day" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource DashTextMutedBrush}"/>
                    <DatePicker x:Name="DayPicker" Width="140" VerticalAlignment="Center"
                                SelectedDateChanged="DayPicker_OnSelectedDateChanged"/>
                    <TextBlock Text="Range" VerticalAlignment="Center" Margin="16,0,8,0"
                               Foreground="{StaticResource DashTextMutedBrush}"/>
                    <ComboBox x:Name="RangeMode" MinWidth="200" MaxWidth="420" Width="280"
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              SelectionChanged="RangeMode_OnSelectionChanged">
                        <ComboBoxItem Content="This calendar day" IsSelected="True"/>
                        <ComboBoxItem Content="7 days ending on selected day"/>
                        <ComboBoxItem Content="14 days ending on selected day"/>
                        <ComboBoxItem Content="28 days ending on selected day"/>
                        <ComboBoxItem Content="Calendar month containing selected day"/>
                    </ComboBox>
                </StackPanel>
                <WrapPanel Orientation="Horizontal">
                    <Border Margin="0,0,8,8" Background="{StaticResource DashAccentBrush}"
                            BorderBrush="{StaticResource DashAccentBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RefreshButton" Grid.Column="0" Content="Refresh"
                                    Style="{StaticResource DashSplitPrimaryLeft}"
                                    Click="Refresh_OnClick"
                                    Padding="14,7,10,7"
                                    ToolTip="Reload the report now"/>
                            <Border Grid.Column="1" Background="#66FFFFFF" Margin="0,8"/>
                            <Button x:Name="RefreshOptionsButton" Grid.Column="2"
                                    Style="{StaticResource DashSplitPrimaryRight}"
                                    Content="▼" ToolTip="Refresh options"
                                    Click="RefreshOptions_OnClick"
                                    FontSize="11" Width="30" Padding="0"
                                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="ContinuousRefreshMenuItem"
                                                  Header="Continuous refresh while dashboard is open"
                                                  IsCheckable="True"
                                                  Click="ContinuousRefreshMenuItem_OnClick"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </Border>
                    <Button Content="Tune detection…" Style="{StaticResource DashToolbarButton}" Click="TuneDetection_OnClick"
                            ToolTip="Review samples vs what you were doing; suggest per-process idle overrides (PIN if set)."/>
                    <Button Content="Merge categories…" Style="{StaticResource DashToolbarButton}" Click="MergeCategories_OnClick"/>
                    <Button Content="Settings…" Style="{StaticResource DashToolbarButton}" Click="Settings_OnClick"/>
                    <Button Content="Rules…" Style="{StaticResource DashToolbarButton}" Click="Rules_OnClick"/>
                    <Button Content="Export HTML…" Style="{StaticResource DashToolbarButton}" Click="Export_OnClick"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Catch up / what's new (in-dashboard; no floating overlay) -->
        <Border x:Name="CatchUpCard" Grid.Row="2" Style="{StaticResource DashCardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <StackPanel x:Name="CatchUpTourPanel" Visibility="Collapsed">
                    <TextBlock Text="Walkthrough" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}"/>
                    <TextBlock x:Name="CatchUpTourTitle" Style="{StaticResource DashSectionTitle}" Margin="0,2,0,6"/>
                    <TextBlock x:Name="CatchUpTourBody" Style="{StaticResource DashBodyText}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CatchUpTourStepCounter" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CatchUpTourSkipButton" Content="Skip" Padding="12,6" Margin="0,0,8,0"
                                Style="{StaticResource DashToolbarButton}" Click="CatchUpTourSkip_OnClick"/>
                        <Button x:Name="CatchUpTourNextButton" Content="Next" Padding="14,6"
                                Style="{StaticResource DashPrimaryButton}" Click="CatchUpTourNext_OnClick"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="CatchUpWhatsNewPanel" Visibility="Collapsed">
                    <TextBlock Text="What's new" FontSize="11" Foreground="{StaticResource DashAccentBrush}"/>
                    <TextBlock x:Name="CatchUpWhatsNewTitle" Style="{StaticResource DashSectionTitle}" Margin="0,2,0,8"/>
                    <TextBlock x:Name="CatchUpWhatsNewBody" Style="{StaticResource DashBodyText}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Button x:Name="CatchUpWhatsNewDoneButton" Content="Got it" Padding="14,6" HorizontalAlignment="Right"
                            Style="{StaticResource DashPrimaryButton}" Click="CatchUpWhatsNewDone_OnClick"/>
                </StackPanel>

                <DockPanel x:Name="CatchUpIdlePanel">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="CatchUpReplayButton" Content="Replay walkthrough" Padding="10,6" Margin="0,0,8,0"
                                Style="{StaticResource DashToolbarButton}" Click="DashboardTour_OnClick"/>
                        <Button x:Name="CatchUpWhatsNewLinkButton" Content="What's new" Padding="10,6"
                                Style="{StaticResource DashToolbarButton}" Click="CatchUpShowWhatsNew_OnClick"
                                Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="CatchUpIdleTitle" Text="All caught up!" Style="{StaticResource DashSectionTitle}"/>
                        <TextBlock x:Name="CatchUpIdleSubtitle" Text="Nothing new here — you're up to speed on this dashboard."
                                   Foreground="{StaticResource DashTextMutedBrush}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- At-a-glance metrics -->
        <Border x:Name="TutorialMetricsHost" Grid.Row="3" Margin="0,0,0,12">
        <UniformGrid Columns="4">
            <Border Background="{StaticResource DashMetricBgBrush}" BorderBrush="{StaticResource DashBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="On computer" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}"/>
                    <TextBlock x:Name="MetricOnComputer" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DashTextPrimaryBrush}" Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource DashMetricBgBrush}" BorderBrush="{StaticResource DashBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Active" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}"/>
                    <TextBlock x:Name="MetricActive" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DashAccentBrush}" Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource DashMetricBgBrush}" BorderBrush="{StaticResource DashBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Thinking" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}"/>
                    <TextBlock x:Name="MetricThinking" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DashTextPrimaryBrush}" Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource DashMetricBgBrush}" BorderBrush="{StaticResource DashBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Idle / AFK" FontSize="11" Foreground="{StaticResource DashTextMutedBrush}"/>
                    <TextBlock x:Name="MetricIdle" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DashTextMutedBrush}" Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        </Border>

        <ScrollViewer x:Name="MainReportScrollViewer" Grid.Row="4"
                      Background="{StaticResource DashBgBrush}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chart -->
                <Border x:Name="TutorialChartHost" Grid.Row="0" Style="{StaticResource DashCardBorder}" Margin="0,0,0,12">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ChartTitle" Text="Hourly activity" Style="{StaticResource DashSectionTitle}"
                                       VerticalAlignment="Center"/>
                            <WrapPanel x:Name="LegendPanel" Grid.Column="1" Margin="16,0,8,0"
                                       Orientation="Horizontal" VerticalAlignment="Center"/>
                            <ComboBox x:Name="LegendDisplayCombo" Grid.Column="2" Width="76" FontSize="11" Padding="6,2"
                                      VerticalAlignment="Center"
                                      ToolTip="Chart legend: show time, percent of engaged time, or both"
                                      SelectionChanged="LegendDisplayCombo_OnSelectionChanged">
                                    <ComboBoxItem Content="Time" Tag="time" IsSelected="True"/>
                                    <ComboBoxItem Content="%" Tag="percent"/>
                                    <ComboBoxItem Content="Both" Tag="both"/>
                            </ComboBox>
                        </Grid>
                        <ScrollViewer x:Name="ChartAreaScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="320"
                                      SizeChanged="ChartAreaScrollViewer_OnSizeChanged"
                                      PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                            <Canvas x:Name="ChartCanvas" Height="160" Background="Transparent" ClipToBounds="True"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Details: two independent columns so summary height does not stretch category table -->
                <Grid x:Name="ReportDetailsRoot" Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="ReportDetailsRightColumn" Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="ReportDetailsLeftPanel" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="SummaryReportBorder" Grid.Row="0"
                                Style="{StaticResource DashCardBorder}" Padding="12" Margin="0,0,10,8"
                                PreviewMouseWheel="SummaryBlock_PreviewMouseWheel">
                            <StackPanel>
                                <TextBlock Text="Summary" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>
                                <Border x:Name="SummaryTrackingStatusPanel" Background="{StaticResource DashMetricBgBrush}"
                                        BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                                    <TextBlock x:Name="SummaryTrackingStatusText" TextWrapping="Wrap"
                                               FontSize="13" Foreground="#3D4450" LineHeight="20"/>
                                </Border>
                                <TextBlock x:Name="SummaryText" Style="{StaticResource DashBodyText}"/>
                                <Expander x:Name="SummaryDetailsExpander" Header="More details" IsExpanded="False"
                                          Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="SummaryDetailsText" Style="{StaticResource DashBodyText}"
                                               Margin="0,4,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border x:Name="HighlightsReportBorder" Grid.Row="1"
                                Style="{StaticResource DashCardBorder}" Padding="10" Margin="0,0,10,0"
                                PreviewMouseWheel="HighlightsBlock_PreviewMouseWheel">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Highlights (active time)"
                                       Style="{StaticResource DashSectionTitle}" Margin="2,0,0,8"/>
                            <TabControl x:Name="HighlightsTabs" BorderThickness="0" Background="Transparent">
                                <TabItem Header="YouTube">
                                    <DataGrid x:Name="YouTubeGrid" Style="{StaticResource DashReportDataGrid}"
                                              PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Video" Binding="{Binding Label}" Width="*"/>
                                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                                <TabItem Header="Sites / pages">
                                    <DataGrid x:Name="SiteGrid" Style="{StaticResource DashReportDataGrid}"
                                              PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Page title" Binding="{Binding Label}" Width="*"/>
                                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                                <TabItem Header="Projects">
                                    <DataGrid x:Name="ProjectGrid" Style="{StaticResource DashReportDataGrid}"
                                              PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Project / folder" Binding="{Binding Label}" Width="*"/>
                                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ReportDetailsRightPanel" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="CategoryReportBorder" Grid.Row="0"
                                Style="{StaticResource DashCardBorder}" Padding="10" Margin="10,0,0,8"
                                PreviewMouseWheel="CategoryBlock_PreviewMouseWheel">
                        <StackPanel>
                            <TextBlock Text="By category (double-click for details)"
                                       Style="{StaticResource DashSectionTitle}" Margin="2,0,0,8"/>
                            <DataGrid x:Name="CategoryGrid" Style="{StaticResource DashReportDataGrid}"
                                      MouseDoubleClick="CategoryGrid_OnMouseDoubleClick"
                                      PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="72"/>
                                    <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="72"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Time}" Width="72"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding Share}" Width="44"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        </Border>

                        <Border x:Name="ProcessReportBorder" Grid.Row="1"
                                Style="{StaticResource DashCardBorder}" Padding="10" Margin="10,0,0,0"
                                PreviewMouseWheel="ProcessBlock_PreviewMouseWheel">
                        <StackPanel>
                            <TextBlock Text="By app (engaged time)" Style="{StaticResource DashSectionTitle}" Margin="2,0,0,8"/>
                            <DataGrid x:Name="ProcessGrid" Style="{StaticResource DashReportDataGrid}"
                                      PreviewMouseWheel="BubbleWheelToMainReportScroll_PreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="*"/>
                                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="72"/>
                                    <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="72"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Time}" Width="72"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
