<Window x:Class="WhatAmIDoing.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:WhatAmIDoing.Controls"
        Title="Classification rules"
        Height="760" Width="1000"
        MinHeight="560" MinWidth="880"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.15*" MinHeight="200"/>
            <RowDefinition Height="*" MinHeight="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashCardBorder}" Margin="0,0,0,10" Padding="10,10,6,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="4,0,4,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Your rules" Style="{StaticResource DashSectionTitle}" VerticalAlignment="Center"/>
                        <help:HelpTipButton VerticalAlignment="Center"
                            TipText="Higher priority runs first; the first match wins. Double-click a row to edit. Suggested rules become yours when you save."/>
                        <TextBlock x:Name="StatusText" Style="{StaticResource DashHintText}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TabControl x:Name="RulesFilterTabs" Margin="0,8,0,0"
                                SelectionChanged="RulesFilterTabs_OnSelectionChanged">
                        <TabItem Header="All"/>
                        <TabItem Header="Apps"/>
                        <TabItem Header="Sites &amp; pages"/>
                    </TabControl>
                </StackPanel>
                <DataGrid x:Name="RulesGrid" Grid.Row="1" Style="{StaticResource DashDataGrid}" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single"
                          MinHeight="160"
                          EnableRowVirtualization="False"
                          EnableColumnVirtualization="False"
                          VirtualizingPanel.IsVirtualizing="False"
                          MouseDoubleClick="RulesGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="42" MinWidth="38"/>
                        <DataGridTextColumn Header="Match" Binding="{Binding MatchLabel}" Width="1.35*" MinWidth="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DashDataGridEllipsisText}">
                                    <Setter Property="ToolTip" Value="{Binding MatchLabel}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern}" Width="2*" MinWidth="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DashDataGridEllipsisText}">
                                    <Setter Property="ToolTip" Value="{Binding Pattern}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.25*" MinWidth="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DashDataGridEllipsisText}">
                                    <Setter Property="ToolTip" Value="{Binding Category}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Pri" Binding="{Binding Priority}" Width="38" MinWidth="34"/>
                        <DataGridCheckBoxColumn Header="Skip" Binding="{Binding IgnoreInTotals, Mode=OneWay}" Width="48" MinWidth="44"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DashCardBorder}" Padding="14,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel MaxWidth="920">
                    <TextBlock x:Name="EditorTitleText" Text="Add a rule" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,10"/>

                    <WrapPanel Margin="0,0,0,6">
                        <Button x:Name="CaptureBtn" Content="Capture focused window"
                                Style="{StaticResource DashPrimaryButton}"
                                Click="Capture_OnClick"/>
                        <help:HelpTipButton VerticalAlignment="Center"
                            TipText="1. Click Capture (or pick from open windows).&#10;2. Switch to the app or browser tab before the countdown ends.&#10;3. Pick how to match (app name, window title, or page/video).&#10;4. Choose a category, then Add rule."/>
                        <TextBlock Text="Wait" Style="{StaticResource DashHintText}" VerticalAlignment="Center" Margin="8,0,6,8"/>
                        <ComboBox x:Name="CaptureSecondsBox" Width="72" Margin="0,0,8,8" VerticalAlignment="Center"
                                  SelectionChanged="CaptureSecondsBox_OnSelectionChanged">
                            <ComboBoxItem Content="3 sec" Tag="3" IsSelected="True"/>
                            <ComboBoxItem Content="5 sec" Tag="5"/>
                            <ComboBoxItem Content="8 sec" Tag="8"/>
                        </ComboBox>
                        <Button Content="Pick from open windows…" Style="{StaticResource DashToolbarButton}"
                                Click="PickOpenWindow_OnClick"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="CancelCaptureBtn" Content="Cancel capture" Style="{StaticResource DashToolbarButton}"
                                Click="CancelCapture_OnClick" Visibility="Collapsed"/>
                        <TextBlock x:Name="CaptureHint" Style="{StaticResource DashHintText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <Border x:Name="CapturePickRow" Visibility="Collapsed" Margin="0,0,0,10"
                            Background="{StaticResource DashMetricBgBrush}"
                            BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="10,8">
                        <WrapPanel>
                            <Button x:Name="PickAppBtn" Style="{StaticResource DashToolbarButton}" Click="PickApp_OnClick"/>
                            <Button x:Name="PickTitleBtn" Style="{StaticResource DashToolbarButton}" Click="PickTitle_OnClick"/>
                            <Button x:Name="PickContextBtn" Style="{StaticResource DashToolbarButton}" Click="PickContext_OnClick" Visibility="Collapsed"/>
                        </WrapPanel>
                    </Border>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="CategoryRow">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="Category" Style="{StaticResource DashHintText}" VerticalAlignment="Center"/>
                                <help:HelpTipButton TipText="Pick an existing label to group with other rules, or type a new one (e.g. School, Games). Time on matching apps rolls up under this name in your report."/>
                            </StackPanel>
                            <ComboBox x:Name="CategoryBox" Grid.Row="1" IsEditable="True" Margin="0,4,0,0"
                                      MinWidth="420" HorizontalAlignment="Stretch"
                                      ToolTip="Same label groups time together in your report (e.g. School, Games)."/>
                        </Grid>
                        <CheckBox x:Name="IgnoreBox" Grid.Column="1" VerticalAlignment="Bottom" Margin="16,0,0,4"
                                  Content="Don't count in totals" Style="{StaticResource DashSimpleCheckBox}"
                                  Checked="IgnoreBox_OnChecked" Unchecked="IgnoreBox_OnChecked"
                                  ToolTip="For background tools — time is logged but not added to totals."/>
                    </Grid>

                    <Expander x:Name="MatchDetailsExpander" Header="Match type and pattern" Style="{StaticResource DashSectionExpander}" IsExpanded="False">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="220" MaxWidth="360"/>
                                <ColumnDefinition Width="*" MinWidth="180"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Match when" Style="{StaticResource DashHintText}"/>
                                    <help:HelpTipButton TipText="How this rule compares to the app, window title, or page/project text from capture."/>
                                </StackPanel>
                                <ComboBox x:Name="MatchKindBox" Margin="0,4,0,0"
                                          SelectionChanged="MatchKindBox_OnSelectionChanged">
                                    <ComboBoxItem Tag="ProcessNameEquals" Content="App name is exactly"/>
                                    <ComboBoxItem Tag="ProcessNameContains" Content="App name contains" IsSelected="True"/>
                                    <ComboBoxItem Tag="WindowTitleContains" Content="Window title contains"/>
                                    <ComboBoxItem Tag="ContextValueContains" Content="Page, video, or project"/>
                                    <ComboBoxItem Tag="ContextSiteContains" Content="Site / page title (browser)"/>
                                    <ComboBoxItem Tag="ContextYouTubeVideoContains" Content="YouTube video title"/>
                                    <ComboBoxItem Tag="ContextProjectContains" Content="IDE project name"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PatternHint" Text="Pattern" Style="{StaticResource DashHintText}"/>
                                <TextBox x:Name="PatternBox" Margin="0,4,0,0"
                                         ToolTip="e.g. comet, youtube.com, khanacademy"/>
                            </StackPanel>
                        </Grid>
                    </Expander>

                    <Expander Header="Advanced (priority, idle overrides, note)" Style="{StaticResource DashSectionExpander}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Priority" Style="{StaticResource DashHintText}"/>
                                <TextBox x:Name="PriorityBox" Text="10" Margin="0,4,0,0"
                                         ToolTip="Higher runs first. Site rules: use above 190 to beat generic browser rules."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Idle (min)" Style="{StaticResource DashHintText}"/>
                                <TextBox x:Name="IdleOverrideBox" Margin="0,4,0,0" ToolTip="Blank = use Settings default"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Thinking (min)" Style="{StaticResource DashHintText}"/>
                                <TextBox x:Name="ThinkingOverrideBox" Margin="0,4,0,0" ToolTip="Blank = use Settings default"/>
                            </StackPanel>
                            <TextBox x:Name="NotesBox" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="72"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="Optional note (shown in the table)"/>
                        </Grid>
                    </Expander>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="AddRuleBtn" Content="Add rule" Style="{StaticResource DashPrimaryButton}" Click="Add_OnClick"/>
                        <Button Content="Edit selected" Style="{StaticResource DashToolbarButton}" Click="EditSelected_OnClick"/>
                        <Button x:Name="CancelEditBtn" Content="Cancel" Style="{StaticResource DashToolbarButton}"
                                Visibility="Collapsed" Click="CancelEdit_OnClick"/>
                        <Button Content="Delete" Style="{StaticResource DashToolbarButton}" Click="Delete_OnClick"/>
                    </WrapPanel>

                    <Expander Header="More actions" Style="{StaticResource DashSectionExpander}" Margin="0,8,0,0">
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Add website rule…" Style="{StaticResource DashToolbarButton}" Click="WebsiteRule_OnClick"/>
                            <Button Content="Restore suggested defaults…" Style="{StaticResource DashToolbarButton}" Click="RestoreDefaults_OnClick"/>
                        </WrapPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
