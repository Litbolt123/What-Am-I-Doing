<Window x:Class="WhatAmIDoing.WebsiteRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add a rule for a website"
        Width="440"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{StaticResource DashBgBrush}">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="16">
        <StackPanel>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource DashBodyText}" Margin="0,0,0,12">
                Enter a site name or paste a link (for example <Run FontStyle="Italic">freecodecamp.org</Run>).
                We match when that text appears in the browser’s extracted page title.
            </TextBlock>
            <TextBlock Text="Website or URL" Style="{StaticResource DashHintText}"/>
            <TextBox x:Name="PatternBox" Margin="0,4,0,12" Padding="6,4"
                     ToolTip="Domain, URL, or a word that appears in the tab title"/>
            <TextBlock Text="Category label" Style="{StaticResource DashHintText}"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,4,0,16"
                      ToolTip="Groups time on your dashboard with this name"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="OK" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Ok_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
