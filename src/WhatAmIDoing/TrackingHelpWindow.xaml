<Window x:Class="WhatAmIDoing.TrackingHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="How tracking works"
        Width="520" Height="520"
        MinHeight="400" MinWidth="440"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="18">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Close" Style="{StaticResource DashPrimaryButton}" IsDefault="True" IsCancel="True" Click="Close_OnClick"/>
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="HelpText" TextWrapping="Wrap" Style="{StaticResource DashBodyText}" LineHeight="22"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
