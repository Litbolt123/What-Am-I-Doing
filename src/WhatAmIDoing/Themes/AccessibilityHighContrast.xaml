<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- High-contrast chrome: strong text and borders; category chart colors unchanged. -->
    <SolidColorBrush x:Key="HcSurface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HcText" Color="#000000"/>
    <SolidColorBrush x:Key="HcMuted" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HcBorder" Color="#000000"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
    </Style>
    <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
    </Style>
    <Style TargetType="DatePicker">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="ListBox">
        <Setter Property="Foreground" Value="{StaticResource HcText}"/>
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HcBorder}"/>
    </Style>
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{StaticResource HcSurface}"/>
    </Style>
</ResourceDictionary>
