<Window x:Class="WhatAmIDoing.PinPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter PIN"
        Height="200" Width="360"
        ShowInTaskbar="True"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="18">
        <StackPanel>
            <TextBlock x:Name="HeaderText" Text="Enter the PIN to continue" Style="{StaticResource DashSectionTitle}" FontSize="14" Margin="0,0,0,10"/>
            <PasswordBox x:Name="PinBox" Height="28" FontSize="14"/>
            <TextBlock x:Name="ErrorText" Foreground="#C0392B" Margin="0,6,0,0" Style="{StaticResource DashHintText}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Style="{StaticResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Unlock" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Ok_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
