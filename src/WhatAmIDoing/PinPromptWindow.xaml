<Window x:Class="WhatAmIDoing.PinPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter PIN"
        Height="200" Width="360"
        ShowInTaskbar="True"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="20" Background="White" CornerRadius="10" Padding="18" BorderBrush="#E8EAEF" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="HeaderText" Text="Enter the PIN to continue" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <PasswordBox x:Name="PinBox" Height="28" FontSize="14"/>
            <TextBlock x:Name="ErrorText" Foreground="#C0392B" Margin="0,6,0,0" FontSize="12" Text=""/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Padding="14,6" Margin="0,0,8,0" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Unlock" Padding="14,6" IsDefault="True" Click="Ok_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
