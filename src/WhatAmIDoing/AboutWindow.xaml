<Window x:Class="WhatAmIDoing.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Height="400" Width="560"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="20" Background="White" CornerRadius="10" Padding="18" BorderBrush="#E8EAEF" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="What Am I Doing" FontWeight="SemiBold" FontSize="18"/>
            <TextBlock x:Name="VersionText" Foreground="#5C6370" Margin="0,4,0,12"/>
            <TextBlock TextWrapping="Wrap" Foreground="#3D4450" Margin="0,0,0,12">
                Local Windows activity tracker that classifies foreground time using your rules
                and produces parent-shareable reports.
            </TextBlock>
            <TextBlock Text="Data location" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="DataPathBox" IsReadOnly="True" Background="#F7F8FA" Padding="6" BorderBrush="#E8EAEF"/>
            <TextBlock x:Name="UpdateStatusText" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#5C6370" FontSize="12"/>
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                <Button Content="Check for updates…" Padding="14,6" Margin="0,0,8,0" Click="CheckUpdates_OnClick"/>
                <Button Content="Open Releases page" Padding="14,6" Margin="0,0,8,0" Click="OpenReleases_OnClick"
                        ToolTip="Opens the project’s GitHub Releases page in your browser (downloads appear there after publish)."/>
                <Button Content="Open data folder" Padding="14,6" Margin="0,0,8,0" Click="OpenFolder_OnClick"/>
                <Button Content="Close" Padding="14,6" IsCancel="True" Click="Close_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
