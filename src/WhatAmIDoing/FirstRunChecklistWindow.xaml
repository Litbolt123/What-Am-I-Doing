<Window x:Class="WhatAmIDoing.FirstRunChecklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome — quick setup"
        Width="440" Height="420"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="16">
        <StackPanel>
            <TextBlock Text="First week checklist" Style="{StaticResource DashSectionTitle}" FontSize="18" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource DashBodyText}" Margin="0,0,0,12">
                Optional steps that make reports meaningful for your household. You can open Settings and Rules anytime from the dashboard.
            </TextBlock>
            <CheckBox x:Name="StepIdleBox" Style="{StaticResource DashSimpleCheckBox}" Content="Review idle &amp; Thinking timing in Settings"/>
            <CheckBox x:Name="StepRulesBox" Style="{StaticResource DashSimpleCheckBox}" Content="Add a website or app rule in Rules (categories &amp; priorities)"/>
            <CheckBox x:Name="StepPinBox" Style="{StaticResource DashSimpleCheckBox}" Content="Set a PIN in Settings if parents should gate Settings / Rules"/>
            <CheckBox x:Name="StepBackupBox" Style="{StaticResource DashSimpleCheckBox}" Content="Export a database backup from Settings (Data backup)"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Don’t show again" Style="{StaticResource DashToolbarButton}" Click="Dismiss_OnClick"/>
                <Button Content="OK" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Ok_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
