<Window x:Class="WhatAmIDoing.CategoryDrillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Category details"
        Height="420" Width="640"
        MinHeight="320" MinWidth="480"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="14">
        <DockPanel>
            <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubText" DockPanel.Dock="Top" Style="{StaticResource DashHintText}" Margin="0,0,0,10"/>
            <DataGrid x:Name="DrillGrid" Style="{StaticResource DashDataGrid}" IsReadOnly="True"
                      HeadersVisibility="Column" CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="First seen" Binding="{Binding FirstSeen}" Width="120"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="120"/>
                    <DataGridTextColumn Header="Window title" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="80"/>
                    <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
