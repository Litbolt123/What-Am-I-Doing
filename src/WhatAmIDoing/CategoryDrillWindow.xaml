<Window x:Class="WhatAmIDoing.CategoryDrillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Category details"
        Height="420" Width="640"
        MinHeight="320" MinWidth="480"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner">
    <Border Margin="16" Background="White" CornerRadius="10" Padding="14"
            BorderBrush="#E8EAEF" BorderThickness="1">
        <DockPanel>
            <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubText" DockPanel.Dock="Top" Foreground="#5C6370" FontSize="12" Margin="0,0,0,10"/>
            <DataGrid x:Name="DrillGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      CanUserResizeRows="False" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="First seen" Binding="{Binding FirstSeen}" Width="120"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="120"/>
                    <DataGridTextColumn Header="Window title" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="80"/>
                    <DataGridTextColumn Header="Thinking" Binding="{Binding Thinking}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
