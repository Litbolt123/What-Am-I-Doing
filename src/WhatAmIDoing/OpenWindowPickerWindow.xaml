<Window x:Class="WhatAmIDoing.OpenWindowPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick an open window"
        Width="560" Height="480"
        MinWidth="440" MinHeight="360"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource DashCardBorder}" Margin="0,0,0,10" Padding="12">
            <TextBlock TextWrapping="Wrap" Style="{StaticResource DashBodyText}"
                       Text="Choose a window below. We'll fill in match and pattern like a capture — no countdown needed."/>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource DashCardBorder}" Padding="8">
            <ListBox x:Name="WindowsList" BorderThickness="0" DisplayMemberPath="DisplayLabel"
                     MouseDoubleClick="WindowsList_OnMouseDoubleClick"/>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource DashCardBorder}" Padding="10,8" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Use selected" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Ok_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
