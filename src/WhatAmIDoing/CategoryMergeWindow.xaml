<Window x:Class="WhatAmIDoing.CategoryMergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge category labels"
        Width="420" Height="320"
        MinWidth="360"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner">
    <Border Margin="16" Background="White" CornerRadius="10" Padding="14" BorderBrush="#E8EAEF" BorderThickness="1">
        <StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#3D4450" Margin="0,0,0,12">
                Renames one category label to another on historical samples, rules, and chart color overrides.
                Built-in rule rows keep their patterns — only the stored category text changes when it matches.
            </TextBlock>
            <TextBlock Text="From label" FontSize="11" Foreground="#5C6370"/>
            <TextBox x:Name="FromBox" Margin="0,4,0,10" Height="28"/>
            <TextBlock Text="To label" FontSize="11" Foreground="#5C6370"/>
            <TextBox x:Name="ToBox" Margin="0,4,0,14" Height="28"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Padding="12,6" Margin="0,0,8,0" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Merge" Padding="14,6" IsDefault="True" Click="Merge_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
