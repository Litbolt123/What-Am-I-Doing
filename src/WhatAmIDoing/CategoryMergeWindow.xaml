<Window x:Class="WhatAmIDoing.CategoryMergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge category labels"
        Width="420" Height="320"
        MinWidth="360"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource DashCardBorder}" Margin="18" Padding="14">
        <StackPanel>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource DashBodyText}" Margin="0,0,0,12">
                Renames one category label to another on historical samples, rules, and chart color overrides.
            </TextBlock>
            <TextBlock Text="From label" Style="{StaticResource DashHintText}"/>
            <TextBox x:Name="FromBox" Margin="0,4,0,10" Height="28"/>
            <TextBlock Text="To label" Style="{StaticResource DashHintText}"/>
            <TextBox x:Name="ToBox" Margin="0,4,0,14" Height="28"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Merge" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Merge_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
