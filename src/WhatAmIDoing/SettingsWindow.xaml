<Window x:Class="WhatAmIDoing.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:WhatAmIDoing.Controls"
        Title="Settings"
        Height="720" Width="560"
        MinWidth="520" MinHeight="480"
        Background="{StaticResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashCardBorder}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Tracking" Style="{StaticResource DashSectionTitle}"/>
                        <help:HelpTipButton TipText="Activity samples stay in the local database until you delete the file or uninstall. Nothing is auto-deleted. Screenshots (if enabled) are separate and expire on their own schedule."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Idle after" Width="108" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="IdleMinutesBox" Width="52" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="min" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                        <help:HelpTipButton TipText="No keyboard, mouse, or (optional) gamepad input for this long → AFK. Individual rules can override."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Thinking extra" Width="108" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="ThinkingMinutesBox" Width="52" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="min" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                        <help:HelpTipButton TipText="Extra grace after idle before fully Idle (0 = off). Example: idle 1 min + thinking 1.5 min → 0–1 min Active, 1–2.5 min Thinking, then Idle."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="Sample every" Width="108" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="SampleSecondsBox" Width="52" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="sec" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                        <help:HelpTipButton TipText="How often the foreground window is checked. Shorter = more CPU; longer idle threshold = AFK kicks in later."/>
                    </StackPanel>

                    <Separator Margin="0,0,0,8"/>
                    <TextBlock Text="Detection" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="AudioDetectionBox" Style="{StaticResource DashSimpleCheckBox}"
                                  Content="Detect voice / mic from other apps"/>
                        <help:HelpTipButton TipText="Records which apps had mic or speaker activity at sample time (e.g. Discord while gaming). Shown as “voice / mic activity” — never claims a specific call."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="PassiveMediaAudioBox" Style="{StaticResource DashSimpleCheckBox}"
                                  Content="Video or music playing counts as active"/>
                        <help:HelpTipButton TipText="Uses the foreground app’s speaker output (not mic). Helps when you’re watching without typing. Works with speakers, headphones, and HDMI/TV."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="PassiveMediaPeakBox" Style="{StaticResource DashSimpleCheckBox}"
                                  Content="Speaker peak fallback (HDMI / TV glitches)"/>
                        <help:HelpTipButton TipText="Treats quiet-but-nonzero speaker peak as still engaged when Windows marks the stream inactive but you still hear sound."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="ControllerInputBox" Style="{StaticResource DashSimpleCheckBox}"
                                  Content="Game controller counts as activity"/>
                        <help:HelpTipButton TipText="XInput gamepads (common Xbox-style). Useful for emulation or games when keyboard/mouse stay still."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="YouTube stretch" Width="108" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="YouTubeScaleBox" Width="48" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="×" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                        <help:HelpTipButton TipText="On YouTube tabs, multiplies idle/Thinking timers when muted or quiet (1–30, default 10)."/>
                    </StackPanel>

                    <Separator Margin="0,0,0,8"/>
                    <CheckBox x:Name="ScreensEnabledBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Periodic screenshots (opt-in)"/>
                    <Expander Header="Screenshot options" Style="{StaticResource DashSectionExpander}">
                        <StackPanel Margin="0,6,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Every" Width="72" Style="{StaticResource DashSettingLabel}"/>
                                <TextBox x:Name="ScreensIntervalSecondsBox" Width="56" Height="26" VerticalContentAlignment="Center"/>
                                <TextBlock Text="sec" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Keep" Width="72" Style="{StaticResource DashSettingLabel}"/>
                                <TextBox x:Name="ScreensRetentionDaysBox" Width="56" Height="26" VerticalContentAlignment="Center"/>
                                <TextBlock Text="days" Margin="8,0,0,0" Style="{StaticResource DashSettingLabel}"/>
                            </StackPanel>
                            <TextBlock Text="Skip when app name contains:" Style="{StaticResource DashHintText}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ScreensExclusionBox" Height="52" AcceptsReturn="True" TextWrapping="Wrap"
                                     ToolTip="Comma-separated process or window name fragments. JPEG captures are encrypted (DPAPI), pause when AFK or screen locked."/>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,4,0,8"/>
                    <TextBlock Text="Family &amp; app" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="AutoStartBox" Style="{StaticResource DashSimpleCheckBox}" Content="Start with Windows"/>
                    <CheckBox x:Name="DesktopShortcutBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Desktop shortcut (updates on Save)"/>
                    <CheckBox x:Name="RequirePinBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="PIN for Settings, Rules, and exit"
                              Checked="RequirePinBox_OnChanged" Unchecked="RequirePinBox_OnChanged"/>
                    <StackPanel x:Name="PinRow" Orientation="Horizontal" Margin="108,0,0,8" Visibility="Collapsed">
                        <TextBlock Text="New PIN" Style="{StaticResource DashSettingLabel}" Margin="0,0,8,0"/>
                        <PasswordBox x:Name="PinBox" Width="120" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="blank = keep current" Style="{StaticResource DashHintText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="LifecycleLoggingBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Log app start, close, and updates in summary"/>
                    <CheckBox x:Name="WatchdogRestartBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Restart if not running (Task Scheduler, every 5 min)"/>
                    <Expander Header="More about PIN and watchdog" Style="{StaticResource DashSectionExpander}">
                        <TextBlock Style="{StaticResource DashHintText}" Margin="0,6,0,0"
                                   Text="Dashboard and HTML export never need the PIN. Settings/Rules ask once per session; tray exit always asks. PIN is a salted hash only. Watchdog is convenience, not tamper-proof — anyone on this account can disable it."/>
                    </Expander>

                    <Separator Margin="0,4,0,8"/>
                    <TextBlock Text="Dashboard" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="QuietHoursEnabledBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Quiet-hours estimate in summary"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Hours" Width="108" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="QuietStartHourBox" Width="40" Height="26" VerticalContentAlignment="Center"
                                 ToolTip="Start hour 0–23"/>
                        <TextBlock Text="to" Margin="8,0,8,0" Style="{StaticResource DashSettingLabel}"/>
                        <TextBox x:Name="QuietEndHourBox" Width="40" Height="26" VerticalContentAlignment="Center"
                                 ToolTip="End hour 0–23 (exclusive unless overnight wrap)"/>
                        <help:HelpTipButton TipText="Local clock hours for engaged-time estimate. End exclusive when start &lt; end (9–17 = 9:00–16:59). If start &gt; end, wraps overnight (22–7)."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Replay tour" Style="{StaticResource DashToolbarButton}" Click="ReplayDashboardTour_OnClick"/>
                        <Button Content="How tracking works…" Style="{StaticResource DashToolbarButton}" Click="OpenTrackingHelp_OnClick"/>
                    </StackPanel>
                    <TextBlock Text="Tour notes" Style="{StaticResource DashHintText}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TutorialNotesBox" MinHeight="56" MaxHeight="100" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <Separator Margin="0,0,0,8"/>
                    <TextBlock Text="Updates" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="AutoCheckUpdatesBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Check for updates on each start"/>
                    <CheckBox x:Name="UpdateTrayNotifyBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Tray notification when an update is found"/>
                    <TextBlock x:Name="SettingsUpdateStatusText" Style="{StaticResource DashHintText}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="SettingsInstallerUpgradePanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <Button x:Name="SettingsDownloadRunInstallerButton" Content="Download and run installer…"
                                Style="{StaticResource DashPrimaryButton}" HorizontalAlignment="Left"
                                Click="DownloadAndRunInstaller_OnClick"
                                ToolTip="Quits the app, saves the installer to Temp, then runs setup. You may see UAC or SmartScreen."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Check now…" Style="{StaticResource DashToolbarButton}" Click="CheckUpdates_OnClick"/>
                        <Button Content="Releases page" Style="{StaticResource DashToolbarButton}" Click="OpenReleases_OnClick"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,8"/>
                    <TextBlock Text="Appearance" Style="{StaticResource DashSectionTitle}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="UiLargeTextBox" Style="{StaticResource DashSimpleCheckBox}" Content="Larger text"/>
                    <CheckBox x:Name="UiHighContrastBox" Style="{StaticResource DashSimpleCheckBox}" Content="Higher contrast"/>
                    <CheckBox x:Name="UiKeyboardHelpersBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Keyboard helpers (underlines, Esc closes)"/>
                    <CheckBox x:Name="BackupReminderBox" Style="{StaticResource DashSimpleCheckBox}"
                              Content="Monthly backup reminder (tray)"/>

                    <Separator Margin="0,8,0,8"/>
                    <Expander Header="Chart colors" Style="{StaticResource DashSectionExpander}">
                        <StackPanel Margin="0,6,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ChartCategoryCombo" IsEditable="True" Margin="0,0,8,0"
                                          ToolTip="Category label from rules or reports"/>
                                <TextBox x:Name="ChartColorHexBox" Grid.Column="1" Text="#00FF00" Margin="0,0,8,0"
                                         VerticalContentAlignment="Center" ToolTip="#RRGGBB or #RGB"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="Pick…" Style="{StaticResource DashToolbarButton}" Margin="0,0,6,0" Click="PickChartColor_OnClick"/>
                                    <Button Content="Save" Style="{StaticResource DashToolbarButton}" Click="AddChartColor_OnClick"/>
                                </StackPanel>
                            </Grid>
                            <ListBox x:Name="ChartColorOverridesList" MaxHeight="140"
                                     BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="88"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Category}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ColorHex}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>
                                            <Button Grid.Column="2" Content="Remove" Style="{StaticResource DashToolbarButton}" Margin="8,0,0,0"
                                                    Click="RemoveChartColor_OnClick"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Backup &amp; data" Style="{StaticResource DashSectionExpander}">
                        <StackPanel Margin="0,6,0,0">
                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="Export backup…" Style="{StaticResource DashToolbarButton}" Click="ExportDatabase_OnClick"/>
                                <Button Content="Import backup…" Style="{StaticResource DashToolbarButton}" Click="ImportDatabase_OnClick"/>
                                <Button Content="Support zip…" Style="{StaticResource DashToolbarButton}" Click="SupportBundle_OnClick"
                                        ToolTip="Log tail + version + redacted settings — no window titles"/>
                                <Button Content="PC handoff zip…" Style="{StaticResource DashToolbarButton}" Click="HandoffZip_OnClick"
                                        ToolTip="Database copy + readme for another PC"/>
                            </WrapPanel>
                            <CheckBox x:Name="KeepDataAfterUninstallBox"
                                      Content="I know activity data may remain after uninstall"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DashCardBorder}" Padding="12,10" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="About" Style="{StaticResource DashToolbarButton}" Click="About_OnClick"/>
                <Button Content="Cancel" Style="{StaticResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Save" Style="{StaticResource DashPrimaryButton}" IsDefault="True" Click="Save_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
