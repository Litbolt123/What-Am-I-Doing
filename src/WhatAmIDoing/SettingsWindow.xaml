<Window x:Class="WhatAmIDoing.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="880" Width="520"
        MinWidth="420"
        Background="#F4F6F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Border Margin="20" Background="White" CornerRadius="10" Padding="18" BorderBrush="#E8EAEF" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Tracking" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>

            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,12">
                Activity samples (time on categories, apps, sites) stay in the local database until you delete the file or uninstall.
                Nothing in the app automatically deletes that history. Optional screenshots below are separate and expire on their own schedule.
            </TextBlock>

            <TextBlock Text="Treat as idle (AFK) after no keyboard or mouse activity for:" Foreground="#3D4450" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,14" VerticalAlignment="Center">
                <TextBox x:Name="IdleMinutesBox" Width="56" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="minutes (global default — individual rules can override this)" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Count as &quot;Thinking&quot; (reading / paused) for an extra:" Foreground="#3D4450" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,6" VerticalAlignment="Center">
                <TextBox x:Name="ThinkingMinutesBox" Width="56" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="minutes before it becomes fully Idle (0 disables)" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,14">
                Example: with idle = 1 min and thinking = 1.5 min, 0–1 min without input is Active, 1–2.5 min is Thinking (reading code, watching a long paragraph), 2.5+ min is Idle.
            </TextBlock>

            <TextBlock Text="Check foreground window every:" Foreground="#3D4450"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,18" VerticalAlignment="Center">
                <TextBox x:Name="SampleSecondsBox" Width="56" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="seconds" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,16">
                Shorter samples use more CPU; longer idle time means AFK kicks in later.
            </TextBlock>

            <Separator Margin="0,0,0,10"/>
            <TextBlock Text="Voice / call detection" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <CheckBox x:Name="AudioDetectionBox" Margin="0,0,0,6"
                      Content="Detect mic and speaker activity from other apps"/>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,8">
                When on, we record which apps had an active microphone or audio session at sample time
                (for example, Discord while you are playing a game). The report shows this as
                “voice / mic activity” and never claims you are in a specific call.
            </TextBlock>

            <TextBlock Text="Video &amp; long-form watching" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
            <CheckBox x:Name="PassiveMediaAudioBox" Margin="0,0,0,6"
                      Content="If the focused app is playing sound (video, music, documentary), don’t count no-keyboard time as AFK"/>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,6">
                We check Windows’ speaker (not mic) for the *foreground* app. Netflix in the browser, movies, and YouTube with audio stay &quot;active&quot; on purpose so passively watching is not the same as walking away. If you mute, the option below still helps for YouTube tabs.
            </TextBlock>
            <TextBlock Text="On YouTube tabs, stretch idle/Thinking (muted or quiet) by this factor" Foreground="#3D4450" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                <TextBox x:Name="YouTubeScaleBox" Width="48" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="× (1–30, default 10. Example: global 1 min idle → up to 10 min before &quot;Thinking&quot; on a muted YouTube tab when sound isn’t keeping you active.)"
                           Margin="10,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#5C6370" FontSize="12"/>
            </StackPanel>

            <Separator Margin="0,8,0,10"/>
            <TextBlock Text="Screen captures (opt-in)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <CheckBox x:Name="ScreensEnabledBox" Margin="0,0,0,8"
                      Content="Take periodic screenshots and OCR them"/>

            <TextBlock Text="Capture every:" Foreground="#3D4450"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,10" VerticalAlignment="Center">
                <TextBox x:Name="ScreensIntervalSecondsBox" Width="70" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="seconds (minimum 5)" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#5C6370"/>
            </StackPanel>

            <TextBlock Text="Keep captures for:" Foreground="#3D4450"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,10" VerticalAlignment="Center">
                <TextBox x:Name="ScreensRetentionDaysBox" Width="70" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="days, then automatically deleted" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#5C6370"/>
            </StackPanel>

            <TextBlock Text="Never capture when foreground app contains (comma separated):" Foreground="#3D4450"/>
            <TextBox x:Name="ScreensExclusionBox" Margin="0,4,0,10" Height="58" AcceptsReturn="True" TextWrapping="Wrap"/>

            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,6">
                Captures are JPEGs of your primary screen, downscaled to 1280 px wide and encrypted on disk
                with Windows DPAPI under your user account so other accounts on this PC cannot read them.
                Captures pause automatically when you are AFK or your screen is locked, and the tray menu
                has “Pause for 30 minutes”.
            </TextBlock>

            <Separator Margin="0,4,0,10"/>
            <TextBlock Text="Chart &amp; report colors" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,8">
                Pick a distinct color per category label so the dashboard and exported HTML reports are easier for others to read (for example when several blues looked alike).
                Use #RGB shorthand or #RRGGBB. Special rows “Idle”, “Ignored”, and “Uncategorized” keep their default greys unless you add an override with that exact name.
                The main Save button at the bottom saves this row too (same as Save color).
            </TextBlock>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ChartCategoryCombo" IsEditable="True" Margin="0,0,8,0"
                          ToolTip="Category label — choose from your rules or type any label that appears in reports."/>
                <TextBox x:Name="ChartColorHexBox" Grid.Column="1" Text="#00FF00" Margin="0,0,8,0" VerticalContentAlignment="Center"
                         ToolTip="#RRGGBB or #RGB"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Pick…" Padding="10,4" Margin="0,0,6,0" Click="PickChartColor_OnClick"/>
                    <Button Content="Save color" Padding="10,4" Click="AddChartColor_OnClick"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Saved overrides:" FontSize="11" Foreground="#5C6370" Margin="0,0,0,4"/>
            <ListBox x:Name="ChartColorOverridesList" MaxHeight="160" BorderBrush="#E8EAEF" BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Category}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding ColorHex}" VerticalAlignment="Center"
                                       FontFamily="Consolas" FontSize="12"/>
                            <Button Grid.Column="2" Content="Remove" Padding="8,2" Margin="8,0,0,0"
                                    Click="RemoveChartColor_OnClick"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Separator Margin="0,0,0,10"/>
            <TextBlock Text="Data backup &amp; uninstall" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,8">
                Export saves a full copy of your database (activity history, rules, settings, PIN hash). Import replaces the current database and restarts the app — only use a file you trust.
            </TextBlock>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Export database backup…" Padding="12,6" Margin="0,0,8,0" Click="ExportDatabase_OnClick"/>
                <Button Content="Import database backup…" Padding="12,6" Click="ImportDatabase_OnClick"/>
            </StackPanel>
            <CheckBox x:Name="KeepDataAfterUninstallBox" Margin="0,0,0,8"
                      Content="I understand my activity file can stay on this PC after uninstall (see note below)"/>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,0,0,10">
                The installer only removes the app from Programs. Your database normally remains under
                %LocalAppData%\WhatAmIDoing\ unless you delete it or import a replacement. Export a backup before uninstall if you want to move history to another PC or keep a safe copy.
            </TextBlock>

            <Separator Margin="0,0,0,10"/>
            <TextBlock Text="Family controls" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <CheckBox x:Name="AutoStartBox" Margin="0,0,0,6" Content="Start with Windows (per-user)"/>
            <CheckBox x:Name="RequirePinBox" Margin="0,0,0,6"
                      Content="Require a PIN to open Settings or Rules, or to exit from the tray"
                      Checked="RequirePinBox_OnChanged" Unchecked="RequirePinBox_OnChanged"/>
            <StackPanel x:Name="PinRow" Orientation="Horizontal" Margin="0,4,0,0" Visibility="Collapsed">
                <TextBlock Text="New PIN:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <PasswordBox x:Name="PinBox" Width="120" Height="26" VerticalContentAlignment="Center"/>
                <TextBlock Text="leave blank to keep current PIN" Foreground="#5C6370" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#5C6370" FontSize="12" Margin="0,8,0,0">
                Viewing the dashboard and exporting HTML reports never asks for the PIN. When a PIN is set,
                Settings and Rules ask once per session after you enter it correctly. Exit from the tray always asks again —
                every time — so closing the app stays deliberate. The PIN is stored only as a salted PBKDF2-SHA256 hash.
                Forgetting it means restoring from a backup file or deleting the activity database in your data folder.
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="About" Padding="14,6" Margin="0,0,10,0" Click="About_OnClick"/>
                <Button Content="Cancel" Padding="16,7" Margin="0,0,10,0" IsCancel="True" Click="Cancel_OnClick"/>
                <Button Content="Save" Padding="16,7" IsDefault="True" Click="Save_OnClick"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
